{
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "node -e \"if(!process.env.CI)require('node:child_process').execSync('lefthook install',{stdio:'inherit'})\""
  },
  "lint-staged": {
    "*.{ts,tsx,md}": "prettier --write"
  },
  "devDependencies": {
    "lefthook": "2.1.9",
    "lint-staged": "17.0.8",
    "prettier": "3.9.4"
  }
}
