{
  "name": "@cellarboss/backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/src/index.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "auth:migrate": "better-auth migrate --yes --config ./dist/src/utils/auth.js",
    "migrate": "tsx src/utils/migrate.ts latest",
    "migrate:down": "tsx src/utils/migrate.ts down",
    "seed": "kysely seed run",
    "generate:docs": "tsx scripts/generate-docs.ts"
  },
  "dependencies": {
    "@better-auth/cli": "1.4.21",
    "@cellarboss/types": "workspace:*",
    "@cellarboss/validators": "workspace:*",
    "@hono/node-server": "2.0.8",
    "@hono/zod-openapi": "1.4.0",
    "@hono/zod-validator": "0.8.0",
    "@loglayer/hono": "2.4.0",
    "@loglayer/transport-pino": "3.3.0",
    "@scalar/hono-api-reference": "0.11.9",
    "better-auth": "1.6.23",
    "better-sqlite3": "12.11.1",
    "dotenv": "17.4.2",
    "hono": "4.12.30",
    "kysely": "0.29.3",
    "kysely-ctl": "0.21.0",
    "loglayer": "9.3.0",
    "mysql2": "3.22.6",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "serialize-error": "13.0.1",
    "sharp": "0.35.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "pino-pretty": "13.1.3",
    "tsup": "8.5.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}