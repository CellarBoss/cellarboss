{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/src/index.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "auth:migrate": "pnpm dlx @better-auth/cli@latest migrate --yes --config ./dist/src/utils/auth.js",
    "migrate": "node node_modules/kysely-ctl/dist/bin.mjs migrate latest",
    "migrate:down": "node node_modules/kysely-ctl/dist/bin.mjs migrate down",
    "seed": "node node_modules/kysely-ctl/dist/bin.mjs seed run",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "dependencies": {
    "@cellarboss/types": "workspace:*",
    "@cellarboss/validators": "workspace:*",
    "@hono/node-server": "^1.19.9",
    "@hono/zod-validator": "^0.7.6",
    "better-auth": "^1.4.17",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.4",
    "hono": "^4.11.5",
    "kysely": "^0.28.10",
    "kysely-ctl": "^0.20.0",
    "mysql2": "^3.16.1",
    "pg": "^8.17.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.17",
    "@types/pg": "^8.16.0",
    "@vitest/ui": "^2.0.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^2.0.0"
  }
}