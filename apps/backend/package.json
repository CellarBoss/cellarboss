{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/src/index.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "auth:migrate": "better-auth migrate --yes --config ./dist/src/utils/auth.js",
    "migrate": "tsx src/utils/migrate.ts latest",
    "migrate:down": "tsx src/utils/migrate.ts down",
    "seed": "kysely seed run",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "dependencies": {
    "@better-auth/cli": "1.4.21",
    "@cellarboss/types": "workspace:*",
    "@cellarboss/validators": "workspace:*",
    "@hono/node-server": "^1.19.9",
    "@hono/zod-validator": "0.7.6",
    "better-auth": "1.4.17",
    "better-sqlite3": "12.6.2",
    "dotenv": "17.2.4",
    "hono": "^4.11.5",
    "kysely": "0.28.10",
    "kysely-ctl": "0.20.0",
    "mysql2": "3.16.1",
    "pg": "8.20.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.12.0",
    "@types/pg": "8.18.0",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "prettier": "3.8.1",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}