{
  "name": "@cellarboss/backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/src/index.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "auth:migrate": "better-auth migrate --yes --config ./dist/src/utils/auth.js",
    "migrate": "tsx src/utils/migrate.ts latest",
    "migrate:down": "tsx src/utils/migrate.ts down",
    "seed": "kysely seed run",
    "generate:docs": "tsx scripts/generate-docs.ts"
  },
  "dependencies": {
    "@better-auth/cli": "1.4.21",
    "@cellarboss/types": "workspace:*",
    "@cellarboss/validators": "workspace:*",
    "@hono/node-server": "2.0.0",
    "@hono/zod-openapi": "1.3.0",
    "@hono/zod-validator": "0.7.6",
    "@loglayer/hono": "2.1.0",
    "@loglayer/transport-pino": "3.0.2",
    "@scalar/hono-api-reference": "0.10.10",
    "better-auth": "1.6.6",
    "better-sqlite3": "12.9.0",
    "dotenv": "17.4.2",
    "hono": "4.12.15",
    "kysely": "0.28.16",
    "kysely-ctl": "0.20.0",
    "loglayer": "9.1.0",
    "mysql2": "3.22.2",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "serialize-error": "13.0.1",
    "sharp": "0.34.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.12.2",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "4.1.5",
    "pino-pretty": "13.1.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  }
}