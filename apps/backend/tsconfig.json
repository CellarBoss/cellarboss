{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "rootDir": "../..",
    "outDir": "./dist",
    "paths": {
      "@cellarboss/types": [
        "../../packages/types/src/index.ts"
      ],
      "@cellarboss/validators": [
        "../../packages/validators/src/index.ts"
      ],
      "@controllers/*": [
        "./src/controllers/*"
      ],
      "@middleware/*": [
        "./src/middleware/*"
      ],
      "@utils/*": [
        "./src/utils/*"
      ],
      "@db": [
        "./src/utils/database.ts"
      ],
      "@routes/*": [
        "./src/routes/*"
      ],
      "@schema/*": [
        "./src/schema/*"
      ],
      "@openapi/*": [
        "./src/openapi/*"
      ]
    }
  },
  "exclude": [
    "node_modules"
  ]
}