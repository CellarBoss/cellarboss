{
  "name": "@cellarboss/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "expo lint",
    "test:e2e": "maestro test e2e/smoke/",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:screenshots": "bash docs/screenshots/generate.sh",
    "docs:screenshots:build": "pnpm docs:screenshots && pnpm docs:build"
  },
  "dependencies": {
    "@cellarboss/common": "workspace:*",
    "@cellarboss/types": "workspace:*",
    "@cellarboss/validators": "workspace:*",
    "@expo/metro-runtime": "55.0.6",
    "@react-navigation/native": "7.2.1",
    "@tanstack/react-form": "catalog:",
    "@tanstack/react-query": "catalog:",
    "date-fns": "4.1.0",
    "expo": "55.0.8",
    "expo-constants": "55.0.9",
    "expo-haptics": "55.0.9",
    "expo-linking": "55.0.8",
    "expo-router": "55.0.7",
    "expo-secure-store": "55.0.9",
    "expo-status-bar": "55.0.4",
    "lucide-react-native": "0.577.0",
    "react": "catalog:",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "2.30.0",
    "react-native-paper": "5.15.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "@types/react-native-vector-icons": "6.4.18",
    "babel-preset-expo": "55.0.12",
    "jest": "29.7.0",
    "jest-expo": "55.0.11",
    "react-test-renderer": "catalog:",
    "typescript": "5.9.3",
    "vitepress": "1.6.4"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!(.pnpm|((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@cellarboss/.*))"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "src/__tests__/helpers/"
    ],
    "setupFiles": [
      "<rootDir>/src/__tests__/helpers/mock-haptics.ts"
    ],
    "setupFilesAfterEnv": [
      "@testing-library/react-native/matchers"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/app/**",
      "!src/__tests__/**"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "json-summary"
    ]
  }
}
