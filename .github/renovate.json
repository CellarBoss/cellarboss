{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":pinAllExceptPeerDependencies"
  ],
  "semanticCommits": "enabled",
  "semanticCommitType": "deps",
  "semanticCommitScope": "",
  "prConcurrentLimit": 4,
  "branchConcurrentLimit": 2,
  "prHourlyLimit": 2,
  "draftPR": false,
  "dependencyDashboard": true,
  "postUpdateOptions": ["pnpmDedupe"],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "automergeType": "pr",
    "semanticCommitType": "chore",
    "schedule": ["before 5am on monday"],
    "prConcurrentLimit": 1
  },
  "ignorePaths": [
    "**/dist/**",
    "**/build/**",
    "**/.next/**",
    "**/coverage/**"
  ],
  "packageRules": [
    {
      "enabled": false,
      "matchPackageNames": [
        "/^expo/",
        "/^@expo/",
        "/^react-native/",
        "/^react$/",
        "/^@react-navigation/"
      ]
    },
    {
      "matchUpdateTypes": [
        "patch",
        "digest"
      ],
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "automergeType": "pr",
      "labels": ["skip-changelog"],
      "semanticCommitType": "deps"
    },
    {
      "matchUpdateTypes": [
        "minor"
      ],
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "automergeType": "pr",
      "semanticCommitType": "deps"
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "7 days",
      "automerge": false,
      "semanticCommitType": "deps"
    },
    {
      "matchUpdateTypes": [
        "lockFileMaintenance",
        "pin"
      ],
      "automerge": true,
      "automergeType": "pr",
      "labels": ["skip-changelog"],
      "semanticCommitType": "chore"
    },
    {
      "matchDepTypes": ["devDependencies"],
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "automergeType": "pr",
      "labels": ["skip-changelog"],
      "semanticCommitType": "deps"
    }
  ]
}
