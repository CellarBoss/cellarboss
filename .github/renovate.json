{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":pinAllExceptPeerDependencies"
  ],
  "semanticCommits": "enabled",
  "semanticCommitType": "deps",
  "semanticCommitScope": "",
  "prConcurrentLimit": 4,
  "branchConcurrentLimit": 2,
  "prHourlyLimit": 2,
  "draftPR": false,
  "dependencyDashboard": true,
  "postUpdateOptions": ["pnpmDedupe"],
  "ignorePaths": [
    "**/dist/**",
    "**/build/**",
    "**/.next/**",
    "**/coverage/**"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "automergeType": "pr",
    "semanticCommitType": "chore",
    "schedule": ["before 5am on monday"],
    "prConcurrentLimit": 1
  },
  "packageRules": [
    {
      "description": "Block Expo and React Native ecosystem",
      "matchPackagePatterns": [
        "^expo",
        "^@expo",
        "^react$",
        "^react-native",
        "^@react-native",
        "^@react-navigation"
      ],
      "enabled": false
    },
    {
      "description": "Group non-Expo dependencies",
      "excludePackagePatterns": [
        "^expo",
        "^@expo",
        "^react-native",
        "^@react-native",
        "^@react-navigation"
      ],
      "groupName": "non-expo dependencies"
    },
    {
      "description": "Prevent accidental automerge of Expo/RN",
      "matchPackagePatterns": [
        "^expo",
        "^@expo",
        "^react-native"
      ],
      "automerge": false
    },
    {
      "matchUpdateTypes": ["patch", "digest"],
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "automergeType": "pr",
      "labels": ["skip-changelog"],
      "semanticCommitType": "deps"
    },
    {
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "automergeType": "pr",
      "semanticCommitType": "deps"
    },
    {
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "7 days",
      "automerge": false,
      "semanticCommitType": "deps"
    },
    {
      "matchUpdateTypes": ["lockFileMaintenance", "pin"],
      "automerge": true,
      "automergeType": "pr",
      "labels": ["skip-changelog"],
      "semanticCommitType": "chore"
    },
    {
      "matchDepTypes": ["devDependencies"],
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "automergeType": "pr",
      "labels": ["skip-changelog"],
      "semanticCommitType": "deps"
    },
    {
      "matchPackagePatterns": ["^@types/"],
      "groupName": "types",
      "automerge": true
    }
  ]
}