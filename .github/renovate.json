{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "semanticCommits": "enabled",
  "semanticCommitType": "deps",
  "semanticCommitScope": "",
  "prConcurrentLimit": 8,
  "prHourlyLimit": 2,
  "draftPR": false,
  "dependencyDashboard": true,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "automergeType": "pr",
    "semanticCommitType": "chore"
  },
  "packageRules": [
    {
      "matchUpdateTypes": [
        "patch",
        "digest"
      ],
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "automergeType": "pr",
      "labels": ["skip-changelog"],
      "semanticCommitType": "deps"
    },
    {
      "matchUpdateTypes": [
        "minor"
      ],
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "automergeType": "pr",
      "semanticCommitType": "deps"
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "7 days",
      "automerge": false,
      "semanticCommitType": "deps"
    },
    {
      "matchUpdateTypes": [
        "lockFileMaintenance",
        "pin"
      ],
      "automerge": true,
      "automergeType": "pr",
      "labels": ["skip-changelog"],
      "semanticCommitType": "chore"
    },
    {
      "matchDepTypes": ["devDependencies"],
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "automergeType": "pr",
      "labels": ["skip-changelog"],
      "semanticCommitType": "deps"
    }
  ]
}
