{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":pinAllExceptPeerDependencies"
  ],
  "semanticCommits": "enabled",
  "semanticCommitType": "deps",
  "semanticCommitScope": "",
  "prConcurrentLimit": 4,
  "branchConcurrentLimit": 4,
  "prHourlyLimit": 2,
  "draftPR": false,
  "dependencyDashboard": true,
  "postUpdateOptions": ["pnpmDedupe"],
  "ignorePaths": [
    "**/dist/**",
    "**/build/**",
    "**/.next/**",
    "**/coverage/**"
  ],
  "statusCheckNames": { "minimumReleaseAge": null },
  "repositoryCache": "reset",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "automergeType": "pr",
    "semanticCommitType": "chore",
    "schedule": ["before 5am on monday"],
    "prConcurrentLimit": 1
  },
  "packageRules": [
    {
      "description": "Block Expo and React Native ecosystem",
      "enabled": false,
      "matchPackageNames": [
        "/^expo/",
        "/^@expo/",
        "/^react$/",
        "/^react-dom$/",
        "/^react-native/",
        "/^@react-native/",
        "/^@react-navigation/",
        "/^jest-expo$/",
        "/^babel-preset-expo$/",
        "/^jest$/",
        "/^@types\\/jest$/",
        "/^react-test-renderer$/",
        "/^@testing-library\\/react-native$/",
        "/^lucide-react-native$/"
      ]
    },
    {
      "description": "Do not bump better-call. It is pinned via pnpm overrides to satisfy better-auth's exact peer (@better-auth/core peer-requires better-call 1.3.6) and must move in lockstep with better-auth, not independently - never across the v2 major, which drops the root serializeCookie export better-auth imports. Update manually when @better-auth/cli catches up to the 1.6 line.",
      "matchPackageNames": ["/^better-call$/"],
      "enabled": false
    },
    {
      "matchUpdateTypes": ["patch", "digest"],
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "automergeType": "pr",
      "labels": ["skip-changelog"],
      "semanticCommitType": "deps"
    },
    {
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "automergeType": "pr",
      "semanticCommitType": "deps"
    },
    {
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "7 days",
      "automerge": false,
      "semanticCommitType": "deps"
    },
    {
      "matchUpdateTypes": ["lockFileMaintenance", "pin"],
      "automerge": true,
      "automergeType": "pr",
      "labels": ["skip-changelog"],
      "semanticCommitType": "chore"
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor", "digest"],
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "automergeType": "pr",
      "labels": ["skip-changelog"],
      "semanticCommitType": "deps"
    },
    {
      "groupName": "types",
      "automerge": true,
      "matchPackageNames": [
        "/^@types//"
      ]
    }
  ]
}
