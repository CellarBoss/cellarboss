{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":pinAllExceptPeerDependencies"
  ],
  "semanticCommits": "enabled",
  "semanticCommitType": "deps",
  "semanticCommitScope": "",
  "prConcurrentLimit": 4,
  "branchConcurrentLimit": 4,
  "prHourlyLimit": 2,
  "draftPR": false,
  "dependencyDashboard": true,
  "postUpdateOptions": ["pnpmDedupe"],
  "ignorePaths": [
    "**/dist/**",
    "**/build/**",
    "**/.next/**",
    "**/coverage/**"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "automergeType": "pr",
    "semanticCommitType": "chore",
    "schedule": ["before 5am on monday"],
    "prConcurrentLimit": 1
  },
  "packageRules": [
    {
      "description": "Block Expo and React Native ecosystem",
      "enabled": false,
      "matchPackageNames": [
        "/^expo/",
        "/^@expo/",
        "/^react$/",
        "/^react-dom$/",
        "/^react-native/",
        "/^@react-native/",
        "/^@react-navigation/",
        "/^jest-expo$/",
        "/^babel-preset-expo$/",
        "/^jest$/",
        "/^@types\\/jest$/",
        "/^react-test-renderer$/",
        "/^@testing-library\\/react-native$/",
        "/^lucide-react-native$/"
      ]
    },
    {
      "matchUpdateTypes": ["patch", "digest"],
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "automergeType": "pr",
      "labels": ["skip-changelog"],
      "semanticCommitType": "deps"
    },
    {
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "automergeType": "pr",
      "semanticCommitType": "deps"
    },
    {
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "7 days",
      "automerge": false,
      "semanticCommitType": "deps"
    },
    {
      "matchUpdateTypes": ["lockFileMaintenance", "pin"],
      "automerge": true,
      "automergeType": "pr",
      "labels": ["skip-changelog"],
      "semanticCommitType": "chore"
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor", "digest"],
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "automergeType": "pr",
      "labels": ["skip-changelog"],
      "semanticCommitType": "deps"
    },
    {
      "groupName": "types",
      "automerge": true,
      "matchPackageNames": [
        "/^@types//"
      ]
    }
  ]
}
