      "default": "./src/*.ts"
    }
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cellarboss/types": "workspace:*",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
