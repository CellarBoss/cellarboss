{
  "name": "@cellarboss/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "dependencies": {
    "@cellarboss/types": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.0",
    "typescript": "5.9.3",
    "vite": "8.0.1",
    "vitest": "4.1.0"
  }
}
